---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BackgroundGradients from '../components/BackgroundGradients.astro';
import { getLangFromUrl, getTranslatedPath, withBase } from '../i18n/utils';
import { SOCIAL_LINKS } from '../constants';
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  image?: string;
}

const {
  title,
  description,
  image = withBase('/placeholder-social.jpg'),
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// URLs alternativas para SEO multiidioma
const esUrl = new URL(getTranslatedPath(Astro.url.pathname, 'es'), Astro.site);
const enUrl = new URL(getTranslatedPath(Astro.url.pathname, 'en'), Astro.site);

// JSON-LD: Person + WebSite. Datos centralizados aquí porque BaseLayout es el
// único punto de entrada SEO para todas las páginas (estáticas y dinámicas).
const siteOrigin = Astro.site?.toString().replace(/\/+$/, '') ?? '';
const siteUrl = `${siteOrigin}${withBase('/')}`;
const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Nacho Martínez',
  alternateName: 'Nacho Sizle',
  url: siteUrl,
  image: new URL(withBase('/favicon.png'), Astro.site).toString(),
  jobTitle: 'Frontend Engineer',
  description,
  sameAs: [SOCIAL_LINKS.github, SOCIAL_LINKS.linkedin, SOCIAL_LINKS.threads],
};
const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Nacho Martínez · Portfolio',
  url: siteUrl,
  inLanguage: [lang === 'es' ? 'es-ES' : 'en-US'],
  author: { '@type': 'Person', name: 'Nacho Martínez' },
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <link rel="icon" type="image/png" href={withBase('/favicon.png')} />
    <link rel="manifest" href={withBase('/manifest.webmanifest')} />
    <meta id="theme-color" name="theme-color" content="#F8FAFC" />
    <meta name="generator" content={Astro.generator} />

    <script is:inline>
      const theme = (() => {
        try {
          const storedTheme = localStorage.getItem('theme');
          if (storedTheme === 'light' || storedTheme === 'dark') return storedTheme;
        } catch (e) {}
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) return 'dark';
        return 'light';
      })();

      document.documentElement.classList.toggle('dark', theme === 'dark');
      document.documentElement.style.colorScheme = theme;

      const themeColor = document.getElementById('theme-color');
      if (themeColor) {
        themeColor.setAttribute('content', theme === 'dark' ? '#0B0D10' : '#F8FAFC');
      }
    </script>

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Alternate languages for SEO -->
    <link rel="alternate" hreflang="es" href={esUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={esUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={new URL(image, Astro.site)} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={lang === 'es' ? 'es_ES' : 'en_US'} />
    <meta property="og:locale:alternate" content={lang === 'es' ? 'en_US' : 'es_ES'} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@nachosizle" />
    <meta name="twitter:creator" content="@nachosizle" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site)} />

    <!-- JSON-LD: Person + WebSite -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(personLd)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteLd)} />

    <!-- Google Fonts: JetBrains Mono + VT323 + Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700;800&family=VT323&family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <!-- Umami -->
    <script is:inline defer src="https://cloud.umami.is/script.js" data-website-id="7e7bb8f2-01ba-436c-bc5e-8a999ddb1891"></script>

  </head>
  <body class="bg-[var(--theme-canvas)] text-[var(--theme-text)] font-sans antialiased">
    <BackgroundGradients />
    <Header />
    <main class="relative z-10">
      <slot />
    </main>
    <Footer />
  </body>
</html>
