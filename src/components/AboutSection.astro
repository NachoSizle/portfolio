---
// About Section - Sección principal con composición de componentes
import { getCollection } from 'astro:content';
import ProfilePhoto from './ProfilePhoto.astro';
import TechOrbit from './TechOrbit.astro';
import StatsGrid from './StatsGrid.astro';
import { CAREER_START_YEAR, LANGUAGES, TECHNOLOGIES } from '../constants';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Métricas verificables (PRF-13). Cada número se deriva de una fuente real
// del repo en build-time, eliminando los valores marketing-fluff anteriores.
const yearsOfExperience = new Date().getFullYear() - CAREER_START_YEAR;
const projects = await getCollection('projects');

const stats = [
  { number: `${yearsOfExperience}+`, label: t('about.stats.experience') },
  { number: `${projects.length}`, label: t('about.stats.projects') },
  { number: `${TECHNOLOGIES.length}`, label: t('about.stats.technologies') },
  { number: `${LANGUAGES.length}`, label: t('about.stats.languages') },
];
---

<section class="relative py-12 pb-20 overflow-hidden bg-transparent" id="about" aria-labelledby="about-heading">
  <!-- Ancla in-page compatible con el nav (#experience). Span sin href: HTML válido y focusable con tabindex=-1 para skip-links. -->
  <span id="experience" tabindex="-1" class="sr-only">{t('about.title')}</span>
  <!-- Floating geometric shapes -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute top-1/3 left-1/5 w-4 h-4 bg-primary/20 rounded-full animate-float" style="animation-delay: 1s;"></div>
    <div class="absolute bottom-1/3 right-1/5 w-6 h-6 bg-emerald-500/20 rounded-full animate-float" style="animation-delay: 3s;"></div>
    <div class="absolute top-2/3 left-1/3 w-3 h-3 bg-yellow-500/20 rounded-full animate-float" style="animation-delay: 5s;"></div>
  </div>

  <!-- Header -->
  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 id="about-heading" class="text-4xl font-extrabold tracking-tight sm:text-5xl md:text-6xl text-balance md:leading-20 mb-6 select-none">
        <span class="bg-gradient-to-r from-gray-900 via-primary to-gray-900 dark:from-white dark:via-primary-400 dark:to-white bg-clip-text text-transparent">
          {t('about.title')}
        </span>
      </h2>
      <p class="text-xl text-gray-600 dark:text-gray-300 max-w-3xl mx-auto leading-relaxed select-none" set:html={t('about.subtitle')} />
    </div>
  </div>

  <!-- Main Content - Profile with Orbiting Tech -->
  <div class="relative w-full flex flex-col justify-start items-center min-h-[400px] sm:min-h-[500px]">
    <!-- Container with relative positioning for the orbs -->
    <div class="relative w-[420px] h-[420px] flex items-center justify-center orbit-main-container" style="perspective: 1200px; transform-style: preserve-3d;">
      
      <!-- Central Profile Photo -->
      <ProfilePhoto name="Nacho Martinez" />
      
      <!-- Orbiting Technology Icons -->
      <TechOrbit />
      
    </div>
  </div>

  <!-- Stats Section -->
  <StatsGrid stats={stats} />
</section>

<style>
  @keyframes float {
    0%, 100% { 
      transform: translateY(0px) rotate(0deg); 
    }
    50% { 
      transform: translateY(-20px) rotate(5deg); 
    }
  }
  
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }
  
  /* Desde 610px usamos el tamaño grande del contenedor de órbitas */
  @media (min-width: 610px) {
    .orbit-main-container {
      width: 500px !important;
      height: 500px !important;
    }
  }
</style>