---
// AboutSection — Neo 8-bit · Product Engineering Loop
import StatsGrid from './StatsGrid.astro';
import ProfilePhoto from './ProfilePhoto.astro';
import { getCollection } from 'astro:content';
import { CAREER_START_YEAR, LANGUAGES, TECHNOLOGIES } from '../constants';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const yearsOfExperience = new Date().getFullYear() - CAREER_START_YEAR;
const projects = await getCollection('projects');

const stats = [
  { number: `${yearsOfExperience}+`, label: t('about.stats.experience') },
  { number: `${projects.length}`,    label: t('about.stats.projects') },
  { number: `${TECHNOLOGIES.length}`, label: t('about.stats.technologies') },
  { number: `${LANGUAGES.length}`,   label: t('about.stats.languages') },
];

// Pasos del Product Engineering Loop
const loopSteps = [
  { id: 'DISCOVER', icon: '◈', color: '#58A6FF' },
  { id: 'DESIGN',   icon: '◇', color: '#F5B36B' },
  { id: 'BUILD',    icon: '▣', color: '#5EE6A8' },
  { id: 'SHIP',     icon: '▲', color: '#5EE6A8' },
  { id: 'ITERATE',  icon: '↺', color: '#F5B36B' },
];
---

<section
  class="relative py-10 sm:py-16 pb-12 sm:pb-20 overflow-hidden bg-transparent"
  id="about"
  aria-labelledby="about-heading"
>
  <span id="experience" tabindex="-1" class="sr-only">{t('about.title')}</span>

  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6">

    <!-- Header -->
    <div class="mb-8 sm:mb-12">
      <div class="flex items-center gap-3 mb-2">
        <span class="font-mono text-xs text-[#3DB882] tracking-widest uppercase select-none">// ABOUT</span>
        <div class="h-px flex-1 bg-[#1F2630]"></div>
      </div>
      <h2
        id="about-heading"
        class="text-3xl sm:text-4xl font-extrabold font-mono tracking-tight text-slate-100 select-none"
      >
        {t('about.title')}
      </h2>
    </div>

    <!-- Layout: foto + loop + stats -->
    <div class="grid grid-cols-1 lg:grid-cols-[auto_1fr] gap-8 sm:gap-10 lg:gap-16 items-start">

      <!-- Foto de perfil -->
      <div class="flex justify-center lg:justify-start">
        <div class="border border-[#1F2630] p-1 bg-[#11151A]">
          <ProfilePhoto name="Nacho Martinez" />
        </div>
      </div>

      <!-- Columna derecha: loop + descripción -->
      <div class="space-y-8">

        <!-- Descripción corta -->
        <div class="space-y-1">
          <div class="font-mono text-xs text-[#8B9AB0] tracking-widest uppercase select-none">BIO</div>
          <p class="text-sm text-slate-400 leading-relaxed max-w-xl" set:html={t('about.subtitle')} />
        </div>

        <!-- Product Engineering Loop -->
        <div class="space-y-3">
          <div class="font-mono text-xs text-[#3DB882] tracking-widest uppercase select-none">
            // PRODUCT ENGINEERING LOOP
          </div>

          <!-- Steps row -->
          <div class="loop-scroll-wrapper">
          <div class="loop-steps" role="list" aria-label="Product Engineering Loop">
            {loopSteps.map((step, i) => (
              <div class="loop-step" role="listitem">
                <!-- Icono + label -->
                <div
                  class="step-box border border-[#1F2630] bg-[#11151A] p-3 flex flex-col items-center gap-1.5 transition-all duration-200 hover:border-[#5EE6A8]/50 hover:shadow-[2px_2px_0_#0B0D10]"
                >
                  <span class="step-icon" style={`color: ${step.color}; font-size: 1.2rem; line-height: 1;`}>
                    {step.icon}
                  </span>
                  <span
                    class="font-mono text-[10px] font-bold tracking-widest select-none"
                    style={`color: ${step.color};`}
                  >
                    {step.id}
                  </span>
                </div>

                <!-- Conector (después de cada step menos el último) -->
                {i < loopSteps.length - 1 && (
                  <div class="loop-connector" aria-hidden="true">
                    <span class="font-mono text-[#1F2630] text-xs select-none tracking-widest">·····</span>
                  </div>
                )}
              </div>
            ))}

            <!-- Flecha de vuelta al inicio -->
            <div class="loop-back" aria-hidden="true">
              <span class="font-mono text-[#3D4B5A] text-xs select-none">↩</span>
            </div>
          </div>
          </div><!-- /loop-scroll-wrapper -->
        </div>

      </div>
    </div>

    <!-- Stats Grid -->
    <div class="mt-12">
      <StatsGrid stats={stats} />
    </div>

  </div>
</section>

<style>
  /* Wrapper con fade-right en mobile para indicar scroll */
  .loop-scroll-wrapper {
    position: relative;
  }
  .loop-scroll-wrapper::after {
    content: '';
    position: absolute;
    right: 0;
    top: 0;
    bottom: 0;
    width: 40px;
    background: linear-gradient(to right, transparent, #0B0D10);
    pointer-events: none;
  }
  @media (min-width: 640px) {
    .loop-scroll-wrapper::after {
      display: none;
    }
  }

  .loop-steps {
    display: flex;
    align-items: center;
    flex-wrap: nowrap;
    gap: 0;
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 2px;
  }
  .loop-steps::-webkit-scrollbar {
    display: none;
  }

  .loop-step {
    display: contents;
  }

  .step-box {
    min-width: 72px;
    text-align: center;
    flex-shrink: 0;
  }

  .loop-connector {
    display: flex;
    align-items: center;
    padding: 0 4px;
    flex-shrink: 0;
  }

  .loop-back {
    display: flex;
    align-items: center;
    padding: 0 4px;
    flex-shrink: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .step-box {
      transition: none;
    }
    .step-box:hover {
      transform: none;
      box-shadow: none;
    }
  }
</style>
