---
// ProjectCard — Neo 8-bit · Case Study Format
import type { CollectionEntry } from 'astro:content';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

export interface Props {
  project: CollectionEntry<'projects'>;
  index: number;
  total: number;
}

const { project, index } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { title, description, stack, demoLink, repoLink, date, status, problem, solution, impact } = project.data;

const statusConfig: Record<string, { label: string; color: string; bg: string }> = {
  prod:       { label: 'PROD',       color: '#5EE6A8', bg: 'rgba(94,230,168,0.08)' },
  experiment: { label: 'EXPERIMENT', color: '#F5B36B', bg: 'rgba(245,179,107,0.08)' },
  archived:   { label: 'ARCHIVED',   color: '#8B9AB0', bg: 'rgba(139,154,176,0.08)' },
};

const currentStatus = statusConfig[status ?? 'prod'] ?? statusConfig.prod;
const projectNum = String(index + 1).padStart(2, '0');
---

<li class="project-card-wrapper list-none">
  <article
    class="project-card group relative border border-[#1F2630] bg-[#11151A] overflow-hidden transition-all duration-200 hover:-translate-y-1 hover:border-[#5EE6A8]/40 hover:shadow-[4px_4px_0_#0B0D10]"
    aria-label={title}
  >
    <!-- HEADER -->
    <div class="flex items-center justify-between gap-2 sm:gap-4 px-4 sm:px-5 py-3 border-b border-[#1F2630] bg-[#0D1117]">
      <div class="flex items-center gap-2 sm:gap-3 min-w-0">
        <span class="shrink-0 font-mono text-xs text-[#3DB882] tracking-widest select-none">#{projectNum}</span>
        <h3 class="font-mono text-sm sm:text-base font-bold text-slate-100 leading-tight truncate">
          {title}
        </h3>
      </div>
      <span
        class="shrink-0 px-2 py-0.5 text-xs font-mono font-bold tracking-widest border select-none whitespace-nowrap"
        style={`color: ${currentStatus.color}; border-color: ${currentStatus.color}40; background: ${currentStatus.bg};`}
      >
        [{currentStatus.label}]
      </span>
    </div>

    <!-- BODY -->
    <div class="px-4 sm:px-5 py-4 space-y-4">
      {problem && (
        <div class="space-y-1">
          <div class="font-mono text-xs text-[#3DB882] tracking-widest uppercase select-none">PROBLEM</div>
          <p class="text-sm text-slate-400 leading-relaxed">{problem}</p>
        </div>
      )}
      {solution && (
        <div class="space-y-1">
          <div class="font-mono text-xs text-[#F5B36B] tracking-widest uppercase select-none">SOLUTION</div>
          <p class="text-sm text-slate-300 leading-relaxed">{solution}</p>
        </div>
      )}
      {!problem && !solution && (
        <p class="text-sm text-slate-400 leading-relaxed">{description}</p>
      )}
      <div class="space-y-1.5">
        <div class="font-mono text-xs text-[#8B9AB0] tracking-widest uppercase select-none">STACK</div>
        <div class="flex flex-wrap gap-2">
          {stack.map((tech: string) => (
            <span class="px-2 py-0.5 text-xs font-mono text-slate-300 border border-[#1F2630] bg-[#161B22] hover:border-[#5EE6A8]/50 transition-colors duration-150 select-none">
              {tech}
            </span>
          ))}
        </div>
      </div>
      {impact && (
        <div class="space-y-1">
          <div class="font-mono text-xs text-[#58A6FF] tracking-widest uppercase select-none">IMPACT</div>
          <p class="text-xs font-mono text-slate-400 leading-relaxed">{impact}</p>
        </div>
      )}
    </div>

    <!-- FOOTER -->
    <div class="flex flex-col xs:flex-row sm:flex-row items-start sm:items-center justify-between gap-3 px-4 sm:px-5 py-3 border-t border-[#1F2630] bg-[#0D1117]">
      <time
        datetime={date.toISOString()}
        class="font-mono text-xs text-[#3D4B5A] select-none"
      >
        {date.toISOString().split('T')[0]}
      </time>
      <div class="flex items-center gap-2 sm:gap-3 flex-wrap">
        {demoLink && (
          <a
            href={demoLink}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 px-3 py-2 min-h-[44px] text-xs font-mono font-bold text-[#0B0D10] bg-[#5EE6A8] border border-[#5EE6A8] transition-all duration-150 hover:-translate-y-0.5 hover:shadow-[2px_2px_0_#3DB882] focus:outline-none focus-visible:ring-1 focus-visible:ring-[#5EE6A8] select-none uppercase"
            aria-label={`${t('projects.viewDemo')}: ${title}`}
          >
            {t('projects.viewDemo')} ↗
          </a>
        )}
        {repoLink && (
          <a
            href={repoLink}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 px-3 py-2 min-h-[44px] text-xs font-mono font-bold text-[#5EE6A8] bg-transparent border border-[#5EE6A8]/40 transition-all duration-150 hover:border-[#5EE6A8] hover:-translate-y-0.5 hover:shadow-[2px_2px_0_#3DB882] focus:outline-none focus-visible:ring-1 focus-visible:ring-[#5EE6A8] select-none uppercase"
            aria-label={`${t('projects.viewRepository')}: ${title}`}
          >
            {t('projects.viewRepository')} ↗
          </a>
        )}
      </div>
    </div>
  </article>
</li>

<style>
  .project-card-wrapper {
    margin: 0 0 1rem 0;
  }
  .project-card {
    font-family: 'JetBrains Mono', 'Fira Code', ui-monospace, monospace;
  }
  @media (prefers-reduced-motion: reduce) {
    .project-card {
      transition: none;
    }
    .project-card:hover {
      transform: none;
      box-shadow: none;
    }
  }
</style>
