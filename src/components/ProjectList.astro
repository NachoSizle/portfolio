---
import type { CollectionEntry } from 'astro:content';
import ProjectCard from './ProjectCard.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

export interface Props {
  projects: CollectionEntry<'projects'>[];
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { projects } = Astro.props;

const featuredProject = projects.find((project) => project.data.featured);
const otherProjects = projects.filter((project) => !project.data.featured);
const totalProjects = projects.length;
---

<section class="relative mx-auto max-w-6xl px-4 sm:px-6 mb-10 sm:mb-14 mt-0 bg-transparent" aria-labelledby="projects-section" role="region">

  <!-- Header terminal -->
  <div class="mb-8 relative z-10">
    <span id="projects" tabindex="-1" class="sr-only">{t('projects.title')}</span>
    <div class="flex items-center gap-3 mb-2">
      <span class="font-mono text-xs text-[#3DB882] uppercase select-none">// PROJECTS</span>
      <div class="h-px flex-1 bg-[#1F2630]"></div>
      <span class="font-mono text-xs text-[#3D4B5A] select-none">{totalProjects} entries</span>
    </div>
    <h2
      id="projects-section"
      class="text-2xl sm:text-3xl font-extrabold font-mono tracking-normal text-slate-100 select-none"
    >
      {t('projects.title')} <span style="color: var(--theme-accent);">{t('projects.titleHighlight')}</span>
    </h2>
    <p class="mt-2 text-sm sm:text-base leading-6 text-slate-500 font-mono max-w-2xl select-none" set:html={t('projects.subtitle')} />
  </div>

  <!-- Featured project (si existe) -->
  {featuredProject && (
    <div class="mb-8">
      <div class="flex items-center gap-2 mb-3">
        <span class="px-2 py-0.5 text-xs font-mono font-bold text-[#F5B36B] border border-[#F5B36B]/40 bg-[rgba(245,179,107,0.08)] select-none">
          [FEATURED]
        </span>
        <div class="h-px flex-1 bg-[#1F2630]"></div>
      </div>
      <ProjectCard
        project={featuredProject}
        index={0}
        total={totalProjects}
      />
    </div>
  )}

  <!-- Resto de proyectos -->
  {otherProjects.length > 0 && (
    <div>
      {featuredProject && (
        <div class="flex items-center gap-2 mb-3">
          <span class="font-mono text-xs text-[#3D4B5A] select-none">// OTHER PROJECTS</span>
          <div class="h-px flex-1 bg-[#1F2630]"></div>
        </div>
      )}
      <ul class="space-y-4" role="list">
        {otherProjects.map((project, index) => (
          <ProjectCard
            project={project}
            index={featuredProject ? index + 1 : index}
            total={totalProjects}
          />
        ))}
      </ul>
    </div>
  )}

  <!-- CTA GitHub -->
  <div class="mt-12 flex justify-center">
    <a
      href="https://github.com/NachoSizle"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 px-5 py-2.5 min-h-[44px] text-sm font-mono font-bold text-[#5EE6A8] border border-[#5EE6A8]/40 bg-transparent transition-all duration-150 hover:border-[#5EE6A8] hover:-translate-y-0.5 hover:shadow-[2px_2px_0_#3DB882] focus:outline-none focus-visible:ring-1 focus-visible:ring-[#5EE6A8] select-none uppercase"
      aria-label={t('projects.viewMore')}
    >
      {t('projects.likeWhat')} → {t('projects.viewMore')} ↗
    </a>
  </div>
</section>
