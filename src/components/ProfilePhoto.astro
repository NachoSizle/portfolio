---
// Profile Photo Component - Foto de perfil estilo Neo 8-bit
import { Image } from 'astro:assets';
import ProfileImage from '../assets/profile.png';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

export interface Props {
  name: string;
}

const { name } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const photoAlt = t('profile.photoAlt', { name });
const badgeAria = t('profile.badge', { name });
---

<div class="relative z-20">
  <!-- Contenedor Neo 8-bit: rectangular, bordes nítidos -->
  <div class="relative profile-photo-size border border-[#1F2630] bg-[#11151A] shadow-[4px_4px_0_#000] overflow-hidden">
    <!-- Esquinas decorativas Neo 8-bit -->
    <div class="absolute top-0 left-0 w-3 h-3 border-t-2 border-l-2 border-[#5EE6A8] z-10 pointer-events-none"></div>
    <div class="absolute top-0 right-0 w-3 h-3 border-t-2 border-r-2 border-[#5EE6A8] z-10 pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 w-3 h-3 border-b-2 border-l-2 border-[#5EE6A8] z-10 pointer-events-none"></div>
    <div class="absolute bottom-0 right-0 w-3 h-3 border-b-2 border-r-2 border-[#5EE6A8] z-10 pointer-events-none"></div>

    <!-- Foto de perfil -->
    <Image
      src={ProfileImage}
      alt={photoAlt}
      class="w-full h-full object-cover"
      loading="eager"
      width={288}
      height={288}
    />
  </div>

  <!-- Badge estilo terminal -->
  <div class="absolute -bottom-3 left-0 right-0 flex justify-center z-30">
    <div
      class="border border-[#1F2630] bg-[#0B0D10] px-3 py-1 shadow-[2px_2px_0_#000]"
      aria-label={badgeAria}
    >
      <p class="font-mono text-xs text-[#5EE6A8] whitespace-nowrap tracking-normal">$ {name}</p>
    </div>
  </div>
</div>

<style>
  .profile-photo-size {
    width: 224px;
    height: 224px;
  }

  /* Desde 610px usamos el tamaño grande de foto de perfil */
  @media (min-width: 610px) {
    .profile-photo-size {
      width: 288px;
      height: 288px;
    }
  }
</style>
