---
import ThemeToggle from "./ThemeToggle.astro";
import LanguagePicker from "./LanguagePicker.astro";
import { getLangFromUrl, useTranslations, withBase, getTranslatedPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const navLinks = [
  { href: "#about", label: t('nav.about') },
  { href: "#projects", label: t('nav.projects') },
  { href: "#contact", label: t('nav.contact') },
];

// URL de la home en el idioma actual (para fallback de smooth scroll cross-page).
const homeUrl = getTranslatedPath('/', lang);
---

<style>
  :root.dark .scrolled-nav {
    background: rgba(30, 41, 59, 1);
    box-shadow: 0 2px 16px 0 rgba(0, 0, 0, 0.85);
    transition:
      background 0.2s,
      box-shadow 0.2s;
  }

  :root:not(.dark) .scrolled-nav {
    background: rgba(255, 255, 255, 1);
    box-shadow: 0 4px 20px 0 rgba(0, 0, 0, 0.85);
  }
</style>

<header class="sticky top-0 z-200 flex justify-center items-center p-4">
  <nav id="main-nav" class="flex gap-3.5 py-2 px-6 rounded-4xl items-center" role="navigation" aria-label="Main navigation">
    <!-- Enlaces de navegación (solo desktop) -->
    <div class="hidden md:flex gap-3.5 items-center">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="text-gray-800 dark:text-gray-200 hover:text-gray-900 dark:hover:text-gray-100 select-none"
          >
            {link.label}
          </a>
        ))
      }
    </div>

    <!-- Separador (solo desktop) -->
    <div class="hidden md:block h-6 w-px bg-gray-300 dark:bg-gray-700"></div>

    <!-- Controles (siempre visibles) -->
    <div class="flex gap-3 items-center">
      <LanguagePicker />
      <ThemeToggle />

      <!-- Botón hamburguesa (solo mobile) -->
      <button
        id="mobile-menu-toggle"
        type="button"
        class="md:hidden inline-flex items-center justify-center w-9 h-9 rounded-full text-gray-800 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-800 focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500"
        aria-controls="mobile-menu"
        aria-expanded="false"
        aria-label={t('nav.menu.open')}
        data-label-open={t('nav.menu.open')}
        data-label-close={t('nav.menu.close')}
      >
        <svg class="hamburger-open w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg class="hamburger-close w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 6l12 12M18 6L6 18" />
        </svg>
      </button>
    </div>
  </nav>
</header>

<!-- Drawer móvil -->
<div
  id="mobile-menu"
  data-open="false"
  hidden
  class="md:hidden fixed inset-0 z-150 bg-black/40 dark:bg-black/60 backdrop-blur-sm transition-opacity duration-200 ease-out opacity-0 data-[open=true]:opacity-100"
  aria-hidden="true"
>
  <div
    role="dialog"
    aria-modal="true"
    aria-label={t('nav.menu.open')}
    class="absolute top-20 left-1/2 -translate-x-1/2 w-[min(92vw,360px)] rounded-3xl bg-white dark:bg-gray-900 shadow-2xl ring-1 ring-black/5 dark:ring-white/10 p-6 transition-transform duration-200 ease-out -translate-y-2 data-[open=true]:translate-y-0"
    data-mobile-panel
  >
    <ul class="flex flex-col gap-2" role="list">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="block w-full px-4 py-3 rounded-xl text-base font-medium text-gray-800 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-800 focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500"
            data-mobile-link
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</div>

<style>
  /* Respeta prefers-reduced-motion: desactiva transiciones del drawer */
  @media (prefers-reduced-motion: reduce) {
    #mobile-menu,
    #mobile-menu [data-mobile-panel] {
      transition: none !important;
    }
  }
</style>

<script is:inline define:vars={{ HOME_URL: homeUrl }}>
  (function () {
    const NAV_ID = 'main-nav';
    const nav = document.getElementById(NAV_ID);

    // Toggle scrolled-nav class based on scroll position (existing behaviour)
    function updateScrolledNav() {
      if (!nav) return;
      if (window.scrollY > 10) {
        nav.classList.add('scrolled-nav');
      } else {
        nav.classList.remove('scrolled-nav');
      }
    }

    window.addEventListener('scroll', updateScrolledNav, { passive: true });
    // Run once to set initial state
    updateScrolledNav();

    // Helper: compute header height (prefer the header element, fall back to nav)
    function getHeaderHeight() {
      const headerEl = document.querySelector('header');
      if (headerEl) return headerEl.getBoundingClientRect().height;
      return nav ? nav.getBoundingClientRect().height : 0;
    }

    // Smooth scroll to an element accounting for header height and a small gap
    function scrollToElementWithOffset(el, pushState = true) {
      if (!el) return;
      const headerHeight = getHeaderHeight();
      const top = el.getBoundingClientRect().top + window.scrollY - headerHeight;
      // Update URL hash without jumping
      if (pushState && typeof history !== 'undefined') {
        try {
          history.pushState(null, '', `#${el.id}`);
        } catch (e) {}
      }
      window.scrollTo({ top, behavior: 'smooth' });
    }

    // Delegate clicks on in-page anchors inside the nav
    if (nav) {
      nav.addEventListener('click', (ev) => {
        const anchor = ev.target instanceof Element ? ev.target.closest('a[href^="#"]') : null;
        if (!anchor) return;
        const href = anchor.getAttribute('href');
        if (!href || href === '#') return;
        const id = href.slice(1);
        const target = document.getElementById(id);
        if (target) {
          // Section exists on current page, scroll to it
          ev.preventDefault();
          scrollToElementWithOffset(target);
        } else {
          // Section not found, redirect to home page with hash
          ev.preventDefault();
          window.location.href = HOME_URL.replace(/\/$/, '/') + '#' + id;
        }
      });
    }

    // If the page loads with a hash, adjust the initial scroll so the header doesn't cover the title
    document.addEventListener('DOMContentLoaded', () => {
      if (location.hash) {
        const id = location.hash.slice(1);
        const target = document.getElementById(id);
        if (target) {
          // Timeout to allow the browser to finish any native jump before we correct it
          setTimeout(() => scrollToElementWithOffset(target, false), 50);
        }
      }
    });

    // ──────────────────────────────────────────────────────────────────
    // Mobile menu (GYM-98): hamburger toggle, Escape, click outside,
    // focus management y respeto de prefers-reduced-motion (vía CSS).
    // ──────────────────────────────────────────────────────────────────
    const toggle = document.getElementById('mobile-menu-toggle');
    const panel = document.getElementById('mobile-menu');
    const iconOpen = toggle ? toggle.querySelector('.hamburger-open') : null;
    const iconClose = toggle ? toggle.querySelector('.hamburger-close') : null;
    let lastFocused = null;

    function setMobileMenu(open) {
      if (!toggle || !panel) return;
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      const labelOpen = toggle.getAttribute('data-label-open') || 'Open menu';
      const labelClose = toggle.getAttribute('data-label-close') || 'Close menu';
      toggle.setAttribute('aria-label', open ? labelClose : labelOpen);
      panel.setAttribute('data-open', open ? 'true' : 'false');
      panel.setAttribute('aria-hidden', open ? 'false' : 'true');
      if (open) {
        lastFocused = document.activeElement;
        panel.hidden = false;
        document.body.style.overflow = 'hidden';
        if (iconOpen) iconOpen.classList.add('hidden');
        if (iconClose) iconClose.classList.remove('hidden');
        // Focus first link inside the panel
        const firstLink = panel.querySelector('[data-mobile-link]');
        if (firstLink instanceof HTMLElement) firstLink.focus();
      } else {
        document.body.style.overflow = '';
        if (iconOpen) iconOpen.classList.remove('hidden');
        if (iconClose) iconClose.classList.add('hidden');
        // Hide after transition
        setTimeout(() => { if (panel.getAttribute('data-open') === 'false') panel.hidden = true; }, 200);
        if (lastFocused instanceof HTMLElement) lastFocused.focus();
      }
    }

    if (toggle && panel) {
      toggle.addEventListener('click', () => {
        const open = toggle.getAttribute('aria-expanded') !== 'true';
        setMobileMenu(open);
      });

      // Cierre al pulsar Escape
      document.addEventListener('keydown', (ev) => {
        if (ev.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') {
          setMobileMenu(false);
        }
      });

      // Cierre al hacer clic fuera del panel (sobre el backdrop)
      panel.addEventListener('click', (ev) => {
        const inPanel = ev.target instanceof Element ? ev.target.closest('[data-mobile-panel]') : null;
        if (!inPanel) setMobileMenu(false);
      });

      // Cierre al navegar a un enlace del panel
      panel.querySelectorAll('[data-mobile-link]').forEach((a) => {
        a.addEventListener('click', () => setMobileMenu(false));
      });

      // Focus trap básico (Tab/Shift+Tab dentro del panel)
      panel.addEventListener('keydown', (ev) => {
        if (ev.key !== 'Tab') return;
        const focusables = panel.querySelectorAll('a, button, [tabindex]:not([tabindex="-1"])');
        if (!focusables.length) return;
        const first = focusables[0];
        const last = focusables[focusables.length - 1];
        const active = document.activeElement;
        if (ev.shiftKey && active === first) { ev.preventDefault(); last.focus(); }
        else if (!ev.shiftKey && active === last) { ev.preventDefault(); first.focus(); }
      });
    }
  })();
</script>
