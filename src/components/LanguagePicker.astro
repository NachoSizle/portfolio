---
import { languages, ui } from '../i18n/ui';
import { getLangFromUrl, getTranslatedPath, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

function getAlternateUrl(targetLang: string) {
  return getTranslatedPath(Astro.url.pathname, targetLang as keyof typeof ui);
}
---

<div class="relative inline-block">
  <button
    id="language-toggle"
    class="flex items-center gap-2 px-3 py-2 min-h-[44px] border border-[#1F2630] bg-[#11151A] text-slate-400 hover:text-[#5EE6A8] hover:border-[#5EE6A8]/40 font-mono text-xs uppercase tracking-widest transition-all duration-150 select-none focus:outline-none focus-visible:ring-1 focus-visible:ring-[#5EE6A8]"
    aria-label={t('language.change')}
    aria-haspopup="menu"
    aria-expanded="false"
  >
    <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129" />
    </svg>
    <span>{lang}</span>
    <svg class="w-3 h-3 shrink-0 transition-transform duration-150" id="chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </button>

  <div
    id="language-menu"
    role="menu"
    aria-hidden="true"
    class="absolute right-0 mt-1 w-36 border border-[#1F2630] bg-[#11151A] shadow-[2px_2px_0_#000] opacity-0 invisible transition-all duration-150 z-50"
  >
    {Object.entries(languages).map(([code, name]) => (
      <a
        href={getAlternateUrl(code)}
        class={`flex items-center justify-between px-3 py-2.5 font-mono text-xs uppercase tracking-widest transition-colors duration-100 select-none focus:outline-none focus-visible:ring-1 focus-visible:ring-inset focus-visible:ring-[#5EE6A8] ${
          code === lang
            ? 'text-[#5EE6A8] bg-[#161B22]'
            : 'text-slate-400 hover:text-[#5EE6A8] hover:bg-[#161B22]'
        }`}
      >
        <span>{name}</span>
        {code === lang && (
          <svg class="w-3 h-3 text-[#5EE6A8]" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
        )}
      </a>
    ))}
  </div>
</div>

<script>
  const toggle = document.getElementById('language-toggle');
  const menu = document.getElementById('language-menu');
  const chevron = document.getElementById('chevron');

  if (toggle && menu && chevron) {
    toggle.addEventListener('click', () => {
      const isVisible = !menu.classList.contains('invisible');

      if (isVisible) {
        menu.classList.add('opacity-0', 'invisible');
        menu.setAttribute('aria-hidden', 'true');
        toggle.setAttribute('aria-expanded', 'false');
        chevron.style.transform = 'rotate(0deg)';
      } else {
        menu.classList.remove('opacity-0', 'invisible');
        menu.setAttribute('aria-hidden', 'false');
        toggle.setAttribute('aria-expanded', 'true');
        chevron.style.transform = 'rotate(180deg)';
      }
    });

    // Cerrar al hacer clic fuera
    document.addEventListener('click', (e) => {
      const target = e.target;
      if (target instanceof Node && !toggle.contains(target) && !menu.contains(target)) {
        if (!menu.classList.contains('invisible')) {
          menu.classList.add('opacity-0', 'invisible');
          menu.setAttribute('aria-hidden', 'true');
          toggle.setAttribute('aria-expanded', 'false');
          chevron.style.transform = 'rotate(0deg)';
        }
      }
    });
  }
</script>
