---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const labels = {
  toggle: t('theme.toggle'),
  toLight: t('theme.toggle.toLight'),
  toDark: t('theme.toggle.toDark'),
};
---

<button 
  id="theme-toggle"
  class="inline-flex items-center justify-center w-11 h-11 border border-[#1F2630] bg-[#11151A] text-slate-400 hover:text-[#5EE6A8] hover:border-[#5EE6A8]/40 transition-all duration-150 focus:outline-none focus-visible:ring-1 focus-visible:ring-[#5EE6A8] select-none"
  aria-label={labels.toggle}
  aria-pressed="false"
>
  <svg id="theme-toggle-dark-icon" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
  </svg>
  <svg id="theme-toggle-light-icon" class="h-6 w-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
  </svg>
</button>

<!-- Región viva para anunciar cambios de tema a lectores de pantalla -->
<span id="theme-toggle-status" class="sr-only" aria-live="polite" aria-atomic="true"></span>

<script is:inline define:vars={{ THEME_LABELS: labels }}>
  // Anti-flicker (GYM-116): este script va inmediatamente después del botón
  // en el DOM, así que puede ejecutarse sin esperar DOMContentLoaded y
  // sincronizar los iconos con la clase `dark` ya aplicada por el script
  // inline de BaseLayout, evitando el parpadeo del icono incorrecto.
  (function () {
    const themeToggleBtn = document.getElementById('theme-toggle');
    const themeToggleDarkIcon = document.getElementById('theme-toggle-dark-icon');
    const themeToggleLightIcon = document.getElementById('theme-toggle-light-icon');
    const themeStatus = document.getElementById('theme-toggle-status');

    if (!themeToggleBtn || !themeToggleDarkIcon || !themeToggleLightIcon) return;

    function updateTheme(announce) {
      const isDark = document.documentElement.classList.contains('dark');
      const newLabel = isDark ? THEME_LABELS.toLight : THEME_LABELS.toDark;
      themeToggleBtn.setAttribute('aria-label', newLabel);
      themeToggleBtn.setAttribute('title', newLabel);
      themeToggleBtn.setAttribute('aria-pressed', String(isDark));
      if (isDark) {
        themeToggleDarkIcon.classList.remove('hidden');
        themeToggleLightIcon.classList.add('hidden');
      } else {
        themeToggleDarkIcon.classList.add('hidden');
        themeToggleLightIcon.classList.remove('hidden');
      }
      if (announce && themeStatus) {
        themeStatus.textContent = newLabel;
      }
    }

    // Sincroniza iconos inmediatamente (sin DOMContentLoaded).
    updateTheme(false);

    themeToggleBtn.addEventListener('click', () => {
      document.documentElement.classList.toggle('dark');
      const newTheme = document.documentElement.classList.contains('dark') ? 'dark' : 'light';
      try { localStorage.setItem('theme', newTheme); } catch (e) { /* noop */ }
      updateTheme(true);
    });

    // Si el usuario no ha forzado tema explícito, sigue la preferencia del sistema.
    try {
      const mql = window.matchMedia('(prefers-color-scheme: dark)');
      mql.addEventListener('change', (ev) => {
        let stored = null;
        try { stored = localStorage.getItem('theme'); } catch (e) { /* noop */ }
        if (stored) return; // El usuario tiene override manual; no tocar.
        if (ev.matches) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
        updateTheme(true);
      });
    } catch (e) { /* noop */ }
  })();
</script>
