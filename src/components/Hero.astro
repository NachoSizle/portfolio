---
import SocialButton from './SocialButton.astro';
import SystemStatusPanel from './SystemStatusPanel.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { BASE_URL, CV, SOCIAL_LINKS } from '../constants';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="relative isolate overflow-visible" aria-labelledby="hero-section">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 py-6 sm:py-10 lg:py-12 relative z-10">

    <!-- Layout 2 columnas en desktop -->
    <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,1fr)_auto] gap-8 sm:gap-10 lg:gap-12 items-center">

      <!-- Columna izquierda: texto -->
      <div class="space-y-5 sm:space-y-6">

        <!-- Badge de estado "disponible" -->
        <div class="inline-flex items-center gap-2 px-3 py-1.5 border border-[#1F2630] bg-[#11151A] font-mono text-xs text-[#5EE6A8]">
          <span class="w-2 h-2 rounded-full bg-[#5EE6A8] inline-block animate-pulse"></span>
          PRODUCT ENGINEER · AVAILABLE
        </div>

        <!-- H1 alineado a la izquierda -->
        <h1
          id="hero-section"
          class="font-extrabold tracking-normal leading-[1.08] text-slate-100 select-none font-mono hero-title"
        >
          {t('hero.title')}
          <br />
          <span style="color: var(--theme-accent);">{t('hero.title.highlight')}</span>
        </h1>

        <!-- Descripción -->
        <p class="text-base sm:text-lg leading-7 text-slate-400 max-w-2xl select-none">
          {t('hero.description')}
        </p>
        <p class="text-sm leading-6 text-slate-500 max-w-2xl select-none font-mono">
          {t('hero.description.line2')}
        </p>

        <!-- CTAs: touch targets mínimo 44px, full-width en mobile -->
        <div class="flex flex-col sm:flex-row flex-wrap items-stretch sm:items-center gap-3 pt-1">
          <a
            href="#projects"
            aria-label={t('hero.cta.primary')}
            data-umami-event="cta-click"
            data-umami-event-location="hero"
            class="hero-btn-primary inline-flex items-center justify-center gap-2 px-6 py-3 min-h-[44px] text-sm font-bold font-mono text-[#0B0D10] bg-[#5EE6A8] border border-[#5EE6A8] transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[4px_4px_0_#3DB882] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#5EE6A8] select-none uppercase"
          >
            {t('hero.cta.primary')} →
          </a>
          <a
            aria-label={t('hero.cta.cv')}
            href={`${BASE_URL}${CV.path}`}
            download="Nacho_Martinez_CV.pdf"
            target="_blank"
            rel="noopener noreferrer"
            data-umami-event="cv-download"
            data-umami-event-lang={lang}
            class="hero-btn-secondary inline-flex items-center justify-center gap-2 px-6 py-3 min-h-[44px] text-sm font-bold font-mono text-[#5EE6A8] bg-transparent border border-[#5EE6A8] transition-all duration-200 hover:-translate-y-0.5 hover:bg-[#5EE6A8]/10 hover:shadow-[4px_4px_0_#3DB882] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#5EE6A8] select-none uppercase"
          >
            {t('hero.cta.cv')} ↓
          </a>
        </div>

        <!-- Social buttons -->
        <div class="flex flex-wrap gap-3">
          <SocialButton
            href={SOCIAL_LINKS.linkedin}
            label={t('hero.social.linkedin')}
            iconName="linkedin"
            iconClassName="h-5 w-5"
          />
          <SocialButton
            href={SOCIAL_LINKS.threads}
            label={t('hero.social.threads')}
            iconName="threads"
            iconClassName="h-5 w-5"
          />
          <SocialButton
            href={SOCIAL_LINKS.github}
            label={t('hero.social.github')}
            iconName="github"
            iconClassName="h-5 w-5"
          />
        </div>
      </div>

      <!-- Columna derecha: SystemStatusPanel — solo visible en lg+ -->
      <div class="hidden lg:flex justify-end">
        <SystemStatusPanel />
      </div>

    </div>
  </div>
</section>

<style>
  .hero-title {
    font-size: 1.875rem;
    letter-spacing: 0;
  }

  @media (min-width: 640px) {
    .hero-title {
      font-size: 2.375rem;
    }
  }

  @media (min-width: 1024px) {
    .hero-title {
      font-size: 3rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-btn-primary,
    .hero-btn-secondary {
      transition: none;
    }
    .hero-btn-primary:hover,
    .hero-btn-secondary:hover {
      transform: none;
      box-shadow: none;
    }
  }
</style>
