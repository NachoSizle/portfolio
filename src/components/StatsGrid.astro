---
// StatsGrid — Neo 8-bit · Terminal metrics
import { getLangFromUrl, useTranslations } from '../i18n/utils';

export interface Stat {
  number: string;
  label: string;
}

export interface Props {
  stats: Stat[];
}

const { stats } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const subtitles = [
  t('about.stats.experience.subtitle'),
  t('about.stats.projects.subtitle'),
  t('about.stats.technologies.subtitle'),
  t('about.stats.languages.subtitle'),
];

const safeStats = Array.isArray(stats) ? stats.slice(0, 4) : [];
while (safeStats.length < 4) {
  safeStats.push({ number: '-', label: '-' });
}

// Icono ASCII por cada stat
const icons = ['⧖', '◈', '⬡', '⌥'];
---

<div class="relative z-10 max-w-5xl mx-auto px-0 mt-10">
  <div class="flex items-center gap-3 mb-4">
    <span class="font-mono text-xs text-[#3D4B5A] uppercase select-none">// METRICS</span>
    <div class="h-px flex-1 bg-[#1F2630]"></div>
  </div>

  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
    {safeStats.map((stat, i) => (
      <div
        class="stat-card border border-[#1F2630] bg-[#11151A] p-4 flex flex-col gap-2 transition-all duration-150 hover:-translate-y-0.5 hover:border-[#5EE6A8]/40 hover:shadow-[4px_4px_0_#000] group"
      >
        <!-- Icono + número -->
        <div class="flex items-baseline gap-2">
          <span class="font-mono text-[#3D4B5A] text-xs select-none group-hover:text-[#5EE6A8] transition-colors">
            {icons[i]}
          </span>
          <span
            class="stat-number text-[2rem] sm:text-[2.25rem] select-none"
            style="font-family: 'VT323', monospace; line-height: 1; color: var(--theme-accent); letter-spacing: 0;"
          >
            {stat.number}
          </span>
        </div>

        <!-- Label -->
        <div class="font-mono text-xs text-slate-400 leading-snug select-none uppercase">
          {stat.label}
        </div>

        <!-- Subtitle -->
        {subtitles[i] && subtitles[i] !== stat.label && (
          <div class="font-mono text-xs text-[#3D4B5A] leading-5 select-none">
            {subtitles[i]}
          </div>
        )}
      </div>
    ))}
  </div>
</div>

<style>
  @media (prefers-reduced-motion: reduce) {
    .stat-card {
      transition: none;
    }
    .stat-card:hover {
      transform: none;
      box-shadow: none;
    }
  }
</style>
