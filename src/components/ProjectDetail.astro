---
// ProjectDetail — Neo 8-bit · Case Study Edition
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';
import { getLangFromUrl, useTranslations, getTranslatedPath } from '../i18n/utils';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
type TranslationKey = Parameters<typeof t>[0];
const content = project.data;

const { Content } = await render(project);

const stack = Array.isArray(content.stack) ? content.stack : [];

function translateOrRaw(value: string): string {
  if (typeof value !== 'string') return String(value);
  if (value.startsWith('projects.')) return t(value as TranslationKey) || value;
  return value;
}

const title = translateOrRaw(content.title);
const description = translateOrRaw(content.description);
const backHref = getTranslatedPath('/', lang);

const statusConfig: Record<string, { label: string; color: string; border: string; bg: string }> = {
  prod: {
    label: 'PROD',
    color: 'var(--theme-accent)',
    border: 'rgba(var(--theme-accent-rgb), 0.4)',
    bg: 'rgba(var(--theme-accent-rgb), 0.1)',
  },
  experiment: {
    label: 'EXPERIMENT',
    color: 'var(--theme-amber)',
    border: 'rgba(var(--theme-amber-rgb), 0.4)',
    bg: 'rgba(var(--theme-amber-rgb), 0.1)',
  },
  archived: {
    label: 'ARCHIVED',
    color: 'var(--theme-text-muted)',
    border: 'rgba(var(--theme-muted-rgb), 0.4)',
    bg: 'rgba(var(--theme-muted-rgb), 0.1)',
  },
};
const currentStatus = statusConfig[content.status ?? 'prod'] ?? statusConfig.prod;

const dateStr = content.date
  ? content.date.toLocaleDateString(lang === 'es' ? 'es-ES' : 'en-US', { month: 'long', year: 'numeric' })
  : null;
---

<div class="min-h-screen bg-[#0B0D10] text-[#E2E8F0]">

  <!-- ── BARRA DE NAVEGACIÓN ── -->
  <nav class="sticky top-0 z-10 border-b border-[#1F2630] bg-[#0B0D10]/95 backdrop-blur-sm">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 h-12 flex items-center justify-between">
      <a
        href={backHref}
        class="group inline-flex items-center gap-2 font-mono text-xs text-[#5EE6A8] hover:text-[#5EE6A8] focus:outline-none focus-visible:ring-1 focus-visible:ring-[#5EE6A8] select-none transition-colors duration-150"
        aria-label={t('projects.backToList')}
      >
        <span class="transition-transform duration-150 group-hover:-translate-x-0.5">←</span>
        <span class="uppercase">{t('projects.backToList')}</span>
      </a>
      <span
        class="font-mono text-xs font-bold border px-2 py-0.5 select-none"
        style={`color: ${currentStatus.color}; border-color: ${currentStatus.border}; background: ${currentStatus.bg};`}
      >
        [{currentStatus.label}]
      </span>
    </div>
  </nav>

  <main class="mx-auto max-w-5xl px-4 sm:px-6 pb-24">

    <!-- ── HERO DEL PROYECTO ── -->
    <header class="pt-10 pb-8 border-b border-[#1F2630]">
      <!-- Número de proyecto + fecha -->
      <div class="flex items-center gap-3 mb-5">
        <span class="font-mono text-xs text-[#3D4B5A] select-none">PROJECT</span>
        <span class="font-mono text-xs text-[#1F2630] select-none">//</span>
        {dateStr && (
          <time
            datetime={content.date.toISOString()}
            class="font-mono text-xs text-[#3D4B5A] select-none"
          >
            {dateStr}
          </time>
        )}
      </div>

      <!-- Título principal -->
      <h1
        id="project-title"
        class="font-mono text-3xl sm:text-4xl md:text-5xl font-bold tracking-normal text-[#E2E8F0] leading-tight mb-4 select-none"
      >
        {title}
      </h1>

      <!-- Descripción -->
      <p class="text-base sm:text-lg text-[#8B9AB0] leading-relaxed max-w-3xl mb-6">
        {description}
      </p>

      <!-- Stack y CTAs en la misma fila -->
      <div class="flex flex-col sm:flex-row sm:items-center gap-4 sm:gap-6">
        {stack.length > 0 && (
          <ul
            class="flex flex-wrap gap-2"
            role="list"
            aria-label={t('projects.stackOf', { title })}
          >
            {stack.map((tech: string) => (
              <li class="px-2 py-0.5 text-xs font-mono text-[#CBD5E1] border border-[#1F2630] bg-[#161B22] select-none">
                {tech}
              </li>
            ))}
          </ul>
        )}
        <div class="flex items-center gap-3 sm:ml-auto">
          {content.demoLink && (
            <a
              href={content.demoLink}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 px-4 py-2 min-h-[44px] text-xs font-mono font-bold text-[#0B0D10] bg-[#5EE6A8] border border-[#5EE6A8] transition-all duration-150 hover:-translate-y-0.5 hover:shadow-[2px_2px_0_#3DB882] focus:outline-none focus-visible:ring-1 focus-visible:ring-[#5EE6A8] select-none uppercase whitespace-nowrap"
              aria-label={t('projects.demoOf', { title })}
            >
              {t('projects.viewDemo')} ↗
            </a>
          )}
          {content.repoLink && (
            <a
              href={content.repoLink}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 px-4 py-2 min-h-[44px] text-xs font-mono font-bold text-[#5EE6A8] bg-transparent border border-[#5EE6A8]/40 transition-all duration-150 hover:border-[#5EE6A8] hover:-translate-y-0.5 hover:shadow-[2px_2px_0_#3DB882] focus:outline-none focus-visible:ring-1 focus-visible:ring-[#5EE6A8] select-none uppercase whitespace-nowrap"
              aria-label={t('projects.repoOf', { title })}
            >
              {t('projects.viewRepository')} ↗
            </a>
          )}
        </div>
      </div>
    </header>

    <!-- ── COVER IMAGE ── -->
    {content.cover && (
      <div class="relative my-8 overflow-hidden border border-[#1F2630] group/cover">
        <!-- Scanlines overlay -->
        <div class="absolute inset-0 z-10 pointer-events-none scanlines opacity-20"></div>
        <!-- Borde glow al hover -->
        <div class="absolute inset-0 z-10 pointer-events-none border border-[#5EE6A8]/0 group-hover/cover:border-[#5EE6A8]/20 transition-all duration-300"></div>
        <img
          src={content.cover}
          alt={t('projects.coverAlt', { title })}
          width="1275"
          height="850"
          loading="lazy"
          decoding="async"
          class="w-full h-auto object-cover transition-transform duration-700 group-hover/cover:scale-[1.01]"
        />
        <!-- Label esquina inferior izquierda -->
        <div class="absolute bottom-0 left-0 z-20 px-3 py-1 bg-[#0B0D10]/90 border-t border-r border-[#1F2630] font-mono text-xs text-[#3D4B5A] select-none">
          {title}
        </div>
      </div>
    )}

    <!-- ── CASE STUDY: PROBLEM / SOLUTION / IMPACT ── -->
    {(content.problem || content.solution || content.impact) && (
      <section
        class="my-8 grid grid-cols-1 sm:grid-cols-3 gap-0 border border-[#1F2630]"
        aria-label="Case study"
      >
        {content.problem && (
          <div class="px-5 py-5 border-b sm:border-b-0 sm:border-r border-[#1F2630] bg-[#11151A] group hover:bg-[#0D1117] transition-colors duration-150">
            <div class="font-mono text-xs text-[#5EE6A8] uppercase mb-2 select-none flex items-center gap-2">
              <span class="text-[#1F2630] group-hover:text-[#5EE6A8]/40 transition-colors duration-150">▶</span>
              PROBLEM
            </div>
            <p class="text-sm text-[#8B9AB0] leading-relaxed">{content.problem}</p>
          </div>
        )}
        {content.solution && (
          <div class="px-5 py-5 border-b sm:border-b-0 sm:border-r border-[#1F2630] bg-[#11151A] group hover:bg-[#0D1117] transition-colors duration-150">
            <div class="font-mono text-xs text-[#F5B36B] uppercase mb-2 select-none flex items-center gap-2">
              <span class="text-[#1F2630] group-hover:text-[#F5B36B]/40 transition-colors duration-150">▶</span>
              SOLUTION
            </div>
            <p class="text-sm text-[#CBD5E1] leading-relaxed">{content.solution}</p>
          </div>
        )}
        {content.impact && (
          <div class="px-5 py-5 bg-[#11151A] group hover:bg-[#0D1117] transition-colors duration-150">
            <div class="font-mono text-xs text-[#58A6FF] uppercase mb-2 select-none flex items-center gap-2">
              <span class="text-[#1F2630] group-hover:text-[#58A6FF]/40 transition-colors duration-150">▶</span>
              IMPACT
            </div>
            <p class="text-sm font-mono text-[#8B9AB0] leading-6">{content.impact}</p>
          </div>
        )}
      </section>
    )}

    <!-- ── SEPARADOR ── -->
    <div class="flex items-center gap-3 my-8">
      <div class="h-px flex-1 bg-[#1F2630]"></div>
      <span class="font-mono text-xs text-[#3D4B5A] select-none uppercase">case study</span>
      <div class="h-px flex-1 bg-[#1F2630]"></div>
    </div>

    <!-- ── CONTENIDO MDX ── -->
    {Content && (
      <article class="neo-prose max-w-3xl" aria-labelledby="project-title">
        <Content />
      </article>
    )}

    <!-- ── FOOTER DEL CASO ── -->
    <footer class="mt-12 pt-6 border-t border-[#1F2630] flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <a
        href={backHref}
        class="group inline-flex items-center gap-2 font-mono text-xs text-[#5EE6A8] focus:outline-none focus-visible:ring-1 focus-visible:ring-[#5EE6A8] select-none transition-colors duration-150 uppercase"
        aria-label={t('projects.backToList')}
      >
        <span class="transition-transform duration-150 group-hover:-translate-x-0.5">←</span>
        {t('projects.backToList')}
      </a>
      <div class="flex items-center gap-3">
        {content.demoLink && (
          <a
            href={content.demoLink}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 px-4 py-2 min-h-[44px] text-xs font-mono font-bold text-[#0B0D10] bg-[#5EE6A8] border border-[#5EE6A8] transition-all duration-150 hover:-translate-y-0.5 hover:shadow-[2px_2px_0_#3DB882] focus:outline-none focus-visible:ring-1 focus-visible:ring-[#5EE6A8] select-none uppercase"
            aria-label={t('projects.demoOf', { title })}
          >
            {t('projects.viewDemo')} ↗
          </a>
        )}
        {content.repoLink && (
          <a
            href={content.repoLink}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 px-4 py-2 min-h-[44px] text-xs font-mono font-bold text-[#5EE6A8] bg-transparent border border-[#5EE6A8]/40 transition-all duration-150 hover:border-[#5EE6A8] hover:-translate-y-0.5 hover:shadow-[2px_2px_0_#3DB882] focus:outline-none focus-visible:ring-1 focus-visible:ring-[#5EE6A8] select-none uppercase"
            aria-label={t('projects.repoOf', { title })}
          >
            {t('projects.viewRepository')} ↗
          </a>
        )}
      </div>
    </footer>

  </main>
</div>

<style is:global>
  /* ─── Scanlines decorativos ─── */
  .scanlines {
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 0, 0, 0.15) 2px,
      rgba(0, 0, 0, 0.15) 4px
    );
  }
  html:not(.dark) .scanlines {
    background: none;
    opacity: 0;
  }

  /* ─── Neo-prose: estilos del contenido MDX ─── */
  .neo-prose {
    color: #CBD5E1;
    font-size: 0.9375rem;
    line-height: 1.75;
  }

  /* Headings */
  .neo-prose h2 {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 1.125rem;
    font-weight: 700;
    color: #5EE6A8;
    letter-spacing: 0;
    text-transform: uppercase;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #1F2630;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .neo-prose h2::before {
    content: "##";
    color: #1F2630;
    font-size: 0.875rem;
  }

  .neo-prose h3 {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 1rem;
    font-weight: 600;
    color: #F5B36B;
    letter-spacing: 0;
    margin-top: 1.75rem;
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .neo-prose h3::before {
    content: "###";
    color: #1F2630;
    font-size: 0.75rem;
  }

  .neo-prose h4 {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.875rem;
    font-weight: 600;
    color: #58A6FF;
    letter-spacing: 0;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  /* Párrafos */
  .neo-prose p {
    margin-bottom: 1rem;
    color: #CBD5E1;
  }

  /* Strong / em */
  .neo-prose strong {
    font-weight: 700;
    color: #E2E8F0;
  }
  .neo-prose em {
    font-style: italic;
    color: #8B9AB0;
  }

  /* Listas */
  .neo-prose ul {
    margin-bottom: 1rem;
    padding-left: 0;
    list-style: none;
  }
  .neo-prose ul li {
    position: relative;
    padding-left: 1.25rem;
    margin-bottom: 0.375rem;
    color: #CBD5E1;
  }
  .neo-prose ul li::before {
    content: "▸";
    position: absolute;
    left: 0;
    color: #5EE6A8;
    font-size: 0.75rem;
    line-height: 1.75;
  }

  .neo-prose ol {
    margin-bottom: 1rem;
    padding-left: 0;
    list-style: none;
    counter-reset: neo-counter;
  }
  .neo-prose ol li {
    position: relative;
    padding-left: 1.75rem;
    margin-bottom: 0.375rem;
    color: #CBD5E1;
    counter-increment: neo-counter;
  }
  .neo-prose ol li::before {
    content: counter(neo-counter, decimal-leading-zero) ".";
    position: absolute;
    left: 0;
    color: #3DB882;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.75rem;
    line-height: 1.75;
  }

  /* Code inline */
  .neo-prose code {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.8125rem;
    background-color: #161B22;
    color: #5EE6A8;
    padding: 0.125rem 0.375rem;
    border: 1px solid #1F2630;
  }

  /* Bloques de código */
  .neo-prose pre {
    background-color: #11151A;
    border: 1px solid #1F2630;
    border-left: 3px solid #5EE6A8;
    padding: 1rem 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.25rem;
    position: relative;
  }
  .neo-prose pre::before {
    content: "// code";
    display: block;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.6875rem;
    color: #3D4B5A;
    margin-bottom: 0.75rem;
    letter-spacing: 0;
  }
  .neo-prose pre code {
    background: transparent;
    border: none;
    padding: 0;
    color: #CBD5E1;
    font-size: 0.8125rem;
  }

  /* Blockquote */
  .neo-prose blockquote {
    border-left: 3px solid #5EE6A8;
    background-color: #11151A;
    padding: 0.75rem 1rem;
    margin: 1.25rem 0;
  }
  .neo-prose blockquote p {
    color: #8B9AB0;
    font-style: italic;
    margin-bottom: 0;
  }
  .neo-prose blockquote p::before { content: '" '; color: #5EE6A8; }
  .neo-prose blockquote p::after  { content: ' "'; color: #5EE6A8; }

  /* Links */
  .neo-prose a {
    color: #5EE6A8;
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.15s;
  }
  .neo-prose a:hover {
    color: #3DB882;
  }

  /* HR */
  .neo-prose hr {
    border: none;
    border-top: 1px dashed #1F2630;
    margin: 2rem 0;
  }

  /* Tabla */
  .neo-prose table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.25rem;
    font-size: 0.875rem;
  }
  .neo-prose th {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0;
    color: #5EE6A8;
    border-bottom: 1px solid #1F2630;
    padding: 0.5rem 0.75rem;
    text-align: left;
  }
  .neo-prose td {
    color: #CBD5E1;
    border-bottom: 1px solid #1F2630;
    padding: 0.5rem 0.75rem;
  }
  .neo-prose tr:last-child td {
    border-bottom: none;
  }
</style>
