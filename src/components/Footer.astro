---
import { Image } from 'astro:assets';
import ProfileImage from '../assets/profile.png';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { getFooterData } from './footer.data';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const currentYear = new Date().getFullYear();
const { socialLinks, quickLinks } = getFooterData(lang);
---

<footer class="relative text-slate-300 overflow-hidden border-t border-[#1F2630] bg-[#0B0D10] mt-12 sm:mt-16 footer-safe" role="contentinfo">
  <span id="contact" tabindex="-1" class="sr-only">{t('footer.links.contact')}</span>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 sm:gap-12 lg:gap-16 my-8 sm:my-10">

      <!-- Brand Section -->
      <div class="space-y-6">
        <div class="inline-flex items-center gap-3">
          <div class="border border-[#1F2630] bg-[#11151A] overflow-hidden" style="width:40px;height:40px;">
            <Image
              src={ProfileImage}
              alt="Nacho Martinez"
              class="w-full h-full object-cover"
              width={40}
              height={40}
            />
          </div>
          <div>
            <h3 class="text-base font-bold font-mono text-slate-100 select-none">Nacho Sizle</h3>
            <p class="font-mono text-xs text-[#3DB882] select-none">{t('footer.role')}</p>
          </div>
        </div>
        <p class="font-mono text-xs text-slate-500 leading-relaxed max-w-md select-none">
          {t('footer.description')}
        </p>
      </div>

      <!-- Right Side: Navigation + Social -->
      <div class="space-y-8">
        <!-- Navigation Links -->
        <div class="space-y-4">
          <h4 class="font-mono text-xs font-bold uppercase text-[#5EE6A8] select-none">{t('footer.navigation')}</h4>
          <nav class="flex flex-wrap gap-x-4 gap-y-2" aria-label="Footer navigation">
            {quickLinks.map((link) => (
              <a
                href={link.url}
                class="font-mono text-xs text-slate-400 hover:text-[#5EE6A8] transition-colors duration-150 select-none focus:outline-none focus-visible:ring-1 focus-visible:ring-[#5EE6A8]"
              >
                {link.name}
              </a>
            ))}
          </nav>
        </div>

        <!-- Social Links -->
        <div class="space-y-4">
          <h4 class="font-mono text-xs font-bold uppercase text-[#5EE6A8] select-none">{t('footer.connect')}</h4>
          <div class="flex flex-wrap gap-3">
            {socialLinks.map((social) => (
              <a
                href={social.url}
                target="_blank"
                rel="noopener noreferrer"
                class="group inline-flex items-center justify-center w-11 h-11 border border-[#1F2630] bg-[#11151A] text-slate-400 hover:text-[#5EE6A8] hover:border-[#5EE6A8]/40 hover:shadow-[2px_2px_0_#0B0D10] transition-all duration-150"
                aria-label={social.name}
              >
                {social.icon === 'github' && (
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                  </svg>
                )}
                {social.icon === 'linkedin' && (
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                )}
                {social.icon === 'email' && (
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                )}
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-[#1F2630] py-6">
      <div class="flex flex-col sm:flex-row justify-between items-center gap-4">
        <p class="font-mono text-xs text-slate-500 select-none">
          © {currentYear} Nacho Sizle · {t('footer.madeWith')}
          <a href="https://astro.build" class="text-[#5EE6A8] hover:underline transition-colors" target="_blank" rel="noopener noreferrer">Astro</a>
        </p>
        <div class="flex items-center gap-2">
          <span class="w-2 h-2 bg-[#5EE6A8] inline-block animate-pulse"></span>
          <span class="font-mono text-xs text-slate-500 select-none">{t('footer.available')}</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll to top button -->
  <button
    id="scrollToTop"
    class="fixed bottom-6 right-4 sm:bottom-8 sm:right-6 w-11 h-11 border border-[#1F2630] bg-[#11151A] text-slate-400 hover:text-[#5EE6A8] hover:border-[#5EE6A8]/40 hover:shadow-[4px_4px_0_#000] transition-all duration-150 opacity-0 pointer-events-none z-50 cursor-pointer"
    aria-label={t('footer.scrollTop')}
    type="button"
  >
    <svg class="w-5 h-5 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" />
    </svg>
  </button>
</footer>

<script>
  (function () {
    const btn = document.getElementById('scrollToTop');
    if (!btn) return;

    function getScrollBehavior() {
      try {
        return window.matchMedia('(prefers-reduced-motion: reduce)').matches ? 'auto' : 'smooth';
      } catch (e) {
        return 'smooth';
      }
    }

    window.addEventListener('scroll', () => {
      if (window.scrollY > 300) {
        btn.classList.remove('opacity-0', 'pointer-events-none');
        btn.classList.add('opacity-100');
      } else {
        btn.classList.add('opacity-0', 'pointer-events-none');
        btn.classList.remove('opacity-100');
      }
    }, { passive: true });
    btn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: getScrollBehavior() });
    });
  })();
</script>

<style>
  .footer-safe {
    padding-bottom: env(safe-area-inset-bottom, 0px);
  }
  @media (prefers-reduced-motion: reduce) {
    #scrollToTop { transition: none; }
  }
</style>
