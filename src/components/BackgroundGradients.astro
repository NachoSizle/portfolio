---
// Background Técnico Neo 8-bit — Grid de puntos + gradiente sutil
// Siempre oscuro, sin blobs de colores vibrantes
---

<div
  class="fixed inset-0 overflow-hidden pointer-events-none z-0"
  aria-hidden="true"
>
  <!-- Grid de puntos técnico (estilo PCB/terminal) -->
  <div
    class="absolute inset-0"
    style="background-image: radial-gradient(circle, rgba(94, 230, 168, 0.12) 1px, transparent 1px); background-size: 28px 28px;"
  ></div>

  <!-- Gradiente de vignette para dar profundidad -->
  <div
    class="absolute inset-0"
    style="background: radial-gradient(ellipse at center, transparent 40%, rgba(11, 13, 16, 0.7) 100%);"
  ></div>

  <!-- Línea de grid horizontal sutil -->
  <div
    class="absolute inset-0 opacity-20"
    style="background-image: linear-gradient(rgba(94, 230, 168, 0.05) 1px, transparent 1px); background-size: 100% 56px;"
  ></div>
</div>

<style>
  /* Respetar preferencia de movimiento reducido (WCAG 2.3.3) */
  @media (prefers-reduced-motion: reduce) {
    div {
      animation: none !important;
    }
  }
</style>
