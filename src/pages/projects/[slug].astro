---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectDetail from '../../components/ProjectDetail.astro';
import { useTranslations, getLangFromUrl } from '../../i18n/utils';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project: CollectionEntry<'projects'>) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const raw = project.data;
const title = typeof raw.title === 'string' && raw.title.startsWith('projects.')
  ? (t(raw.title as any) as string) || raw.title
  : raw.title;
const description = typeof raw.description === 'string' && raw.description.startsWith('projects.')
  ? (t(raw.description as any) as string) || raw.description
  : raw.description;
---
<BaseLayout title={title} description={description}>
  <ProjectDetail project={project} />
</BaseLayout>
